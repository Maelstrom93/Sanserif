# --- Error pages (solo se il file esiste) ---
# ErrorDocument 403 /403.html

# --- Rewrite on ---
RewriteEngine On

# Non riscrivere file/cartelle reali
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Forza HTTPS (rispetta proxy/CDN)
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# /index.php -> /
RewriteCond %{THE_REQUEST} \s/+(index)\.php[\s?/] [NC]
RewriteRule ^index\.php$ / [R=301,L]

# *.php digitato -> URL senza estensione (redirect esterno)
RewriteCond %{THE_REQUEST} \s/([^\s?]+)\.php(?:[?\s]|$) [NC]
RewriteRule ^ %1 [R=301,L]

# URL senza estensione -> file .php (rewrite interno)
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L]

# (opzionale) /index -> /
RewriteRule ^index/?$ / [R=301,L]

# Charset di default (non forzare Content-Type sugli asset)
AddDefaultCharset UTF-8

# --- RIMUOVI queste direttive se usavi FPM ---
